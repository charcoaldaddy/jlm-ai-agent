# ===========================================
# JLM AI Agent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===================
# LLM Providers
# ===================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# ===================
# Blockchain RPC URLs
# ===================
# Ethereum
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_WS_URL=wss://eth.llamarpc.com/ws

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com/ws

# Base
BASE_RPC_URL=https://mainnet.base.org

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com

# ===================
# Forex/Metals API
# ===================
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=your-oanda-account-id
FOREX_COM_API_KEY=your-forexcom-api-key

# ===================
# Stock Trading API
# ===================
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_PAPER=true

# ===================
# Polymarket
# ===================
POLYMARKET_PRIVATE_KEY=your-wallet-private-key
POLYGON_RPC_URL=https://polygon-rpc.com

# ===================
# Database
# ===================
DATABASE_URL=postgresql://user:password@localhost:5432/jlm_agent

# ===================
# Redis
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# Monitoring
# ===================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# ===================
# Alert Webhooks
# ===================
DISCORD_WEBHOOK_URL=your-discord-webhook-url
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ===================
# Security - MPC Wallet
# ===================
MPC_KEY_SHARD_1=your-mpc-shard-1
MPC_KEY_SHARD_2=your-mpc-shard-2
MPC_KEY_SHARD_3=your-mpc-shard-3

# ===================
# Application Settings
# ===================
NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# ===================
# Trading Settings
# ===================
MAX_POSITION_SIZE=10000
DEFAULT_STOP_LOSS=0.02
DEFAULT_TAKE_PROFIT=0.05
